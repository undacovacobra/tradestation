# Shared secret that TradingView must include in every alert payload.
# Generate a long random string and paste the same value into your TradingView alert message.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Password for opening the dashboard in a browser. REQUIRED if you expose the
# dashboard to the internet (ngrok). Leave empty only for local-only use.
DASHBOARD_PASSWORD=

# Port the server listens on. V4 uses 3500 so V2/V3 can remain available.
PORT=3500
# Local-only by default. A tunnel can still forward to this address.
HOST=127.0.0.1

# V4 account/connection/pool registry and durable per-pool state.
REGISTRY_PATH=data/registry.json
POOL_STATE_DIR=data/pools
HEALTH_CHECK_SECONDS=45

# Default discovery pattern only; each login can override this in registry.json.
ACCOUNT_ID_PATTERN=[A-Z0-9][A-Z0-9_-]{5,}

# Run the Tradovate browser visibly (true) so you can watch / debug, or hidden (false).
HEADED=true

# Folder where the persistent Tradovate browser session is stored (cookies/login).
# You log in (and pass 2FA) ONCE manually; the session is reused after that.
SESSION_DIR=.tradovate-session

# Tradovate web trader URL.
TRADOVATE_URL=https://trader.tradovate.com

# Order-path speed knobs. If Tradovate is set to pop an order-confirmation dialog,
# raise ORDER_CONFIRM_WAIT_MS so the bot has time to see and click it. If your
# orders fire with no confirmation, you can lower it (even to 0) for speed.
ORDER_CONFIRM_WAIT_MS=250
SWITCH_SETTLE_MS=250
# Save a screenshot on every order (slower). Failures always screenshot anyway.
SCREENSHOTS=false

# --- Daily win-bench + profit target ---------------------------------------
# When an account CLOSES A WINNER it rests for the rest of the (futures) trading
# day; losers/breakeven keep cycling. Set false to let every account keep going.
ONCE_PER_DAY=true
# The futures trading day rolls over in the evening, not at midnight. Default is
# the 6pm US/Eastern session reset. Change only if your session boundary differs.
TRADING_DAY_TZ=America/New_York
TRADING_DAY_RESET_HOUR=18
# While a trade is open, how often (seconds) to re-read THAT account's balance to
# catch the profit target. Only reads the already-selected account — never
# switches, never touches the entry click. Nothing happens while flat.
MONITOR_ACTIVE_SECONDS=3
# (The profit target itself — default $53,000 — is set on the dashboard, not here.)

# --- Remote access (ngrok) — powers the dashboard's "Remote access" button ---
# Your ngrok authtoken (ngrok dashboard -> Your Authtoken). Required for the
# button to work. Leave blank to disable remote access entirely.
NGROK_AUTHTOKEN=
# Your permanent ngrok domain, e.g. your-name.ngrok-free.dev (no https://).
NGROK_DOMAIN=
# If true, remote access turns on automatically when the bot starts.
NGROK_AUTOSTART=true

# --- V3 self-healing --------------------------------------------------------
# Open + log into the Tradovate browser automatically when the bot starts
# (no "Connect browser" click needed after a restart). Set false to disable.
AUTO_CONNECT=true

# Phone notifications via Telegram (free). Leave blank to disable.
# 1) In Telegram, message @BotFather -> /newbot -> it gives you a token.
# 2) Message your new bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy your chat "id".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
