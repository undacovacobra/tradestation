{
  "name": "multi-firm-account-orchestrator-v4",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "V4 multi-login, multi-firm account rotation orchestrator with isolated browser workers and safe webhook testing.",
  "scripts": {
    "start": "tsx src/server-v4.ts",
    "dev": "tsx watch src/server-v4.ts",
    "test": "node --import ./test/setup-env.mjs --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "webhook:send": "tsx src/send-test-webhook.ts",
    "testhook": "tsx src/send-test-webhook.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@ngrok/ngrok": "^1.7.0"
  }
}
