# Shared secret that TradingView must include in every alert payload.
# Generate a long random string and paste the same value into your TradingView alert message.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Password for opening the dashboard in a browser. REQUIRED if you expose the
# dashboard to the internet (ngrok). Leave empty only for local-only use.
DASHBOARD_PASSWORD=

# Port the server listens on. V2 uses 3300 so it never clashes with the old bot (3000).
PORT=3300

# Run the Tradovate browser visibly (true) so you can watch / debug, or hidden (false).
HEADED=true

# Speed knobs for the live order path (lower = faster fills). Raise these if your
# PC/connection is slow or Tradovate is set to show an order-confirmation popup.
ORDER_CONFIRM_WAIT_MS=350
SWITCH_SETTLE_MS=300
# Save a screenshot on every order (slower). Failures always screenshot anyway.
SCREENSHOTS=false

# Folder where the persistent Tradovate browser session is stored (cookies/login).
# You log in (and pass 2FA) ONCE manually; the session is reused after that.
SESSION_DIR=.tradovate-session

# Tradovate web trader URL.
TRADOVATE_URL=https://trader.tradovate.com

# If true, an account that closes a WINNING trade sits out the rest of the day
# (a loser/breakeven keeps cycling). If false, accounts cycle endlessly with no
# daily limit. Win/loss is measured from the account balance (EQUITY) before vs
# after the trade, so it only takes effect in LIVE mode.
ONCE_PER_DAY=true

# The futures "trading day" rolls over in the evening, not at midnight. Default
# is 6pm US/Eastern (the CME session reopen). For Central time set
# TRADING_DAY_TZ=America/Chicago. TRADING_DAY_RESET_HOUR is the 0-23 hour it rolls.
TRADING_DAY_TZ=America/New_York
TRADING_DAY_RESET_HOUR=18

# How often (seconds) the bot re-reads the Tradovate account menu to update
# balances, spot new accounts, and enforce the eval profit target ($53,000 by
# default) when NO trade is open. Only runs while the browser is logged in.
MONITOR_SECONDS=60
# Cadence (seconds) for the cheap live-account read WHILE a trade is open (drives
# the profit-target stop). This does NOT switch accounts, so it's light.
MONITOR_ACTIVE_SECONDS=3

# How often (MINUTES) to refresh EVERY account's balance in the background. This
# switches through all accounts, which competes with trades for the one browser,
# so it's OFF by default (0) to keep trades instant. Idle balances still refresh
# whenever you press "Scan", and the live account refreshes during a trade.
# Set e.g. 10 if you want idle balances auto-refreshed every 10 minutes.
BALANCE_SWEEP_MINUTES=0

# --- Remote access (ngrok) — powers the dashboard's "Remote access" button ---
# Your ngrok authtoken (ngrok dashboard -> Your Authtoken). Required for the
# button to work. Leave blank to disable remote access entirely.
NGROK_AUTHTOKEN=
# Your permanent ngrok domain, e.g. your-name.ngrok-free.dev (no https://).
# Leave blank to get a random address each time.
NGROK_DOMAIN=
# If true, remote access turns on automatically when the bot starts.
NGROK_AUTOSTART=true
