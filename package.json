{
  "name": "tradovate-account-cycler-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Non-API trading bot that receives TradingView webhook alerts and cycles trades across multiple Tradovate prop accounts via browser automation.",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "calibrate": "tsx src/executor/calibrate.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
