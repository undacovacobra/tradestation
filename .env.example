# Shared secret that TradingView must include in every alert payload.
# Generate a long random string and paste the same value into your TradingView alert message.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Port the local webhook server listens on.
PORT=3000

# Execution mode:
#   dryrun   -> logs what it WOULD do, never touches a broker. Use this to test safely.
#   tradovate -> drives the real Tradovate web trader via a browser. Live orders!
EXECUTOR=dryrun

# When EXECUTOR=tradovate:
# Run the browser visibly (true) so you can watch / debug, or headless (false).
HEADED=true

# Folder where the persistent Tradovate browser session is stored (cookies/login).
# You log in (and pass 2FA) ONCE manually; the session is reused after that.
SESSION_DIR=.tradovate-session

# Tradovate web trader URL (demo vs live differ).
TRADOVATE_URL=https://trader.tradovate.com

# If true, an account will not be traded twice on the same calendar day even if
# the rotation comes back around to it. Matches "only trade 1 account per day".
ONCE_PER_DAY=true
