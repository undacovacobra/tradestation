  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@ngrok/ngrok": "^1.7.0"
  }
}
