{
  "name": "tradovate-account-cycler-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "V3 (self-healing test copy of V2, port 3400): auto-connect on boot, popup-killer, phone notifications, crash watchdog. Browser automation, no API.",
